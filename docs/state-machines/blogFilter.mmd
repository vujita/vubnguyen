stateDiagram-v2
  state blogFilter {
    state search {
      [*] --> idle
      idle --> active : SET_QUERY
      active --> idle : SET_QUERY
      active --> active : SET_QUERY
      active --> idle : CLEAR_ALL
    }
    --
    state tagFilter {
      [*] --> empty
      empty --> filtering : TOGGLE_TAG
      filtering --> empty : TOGGLE_TAG
      filtering --> filtering : TOGGLE_TAG
      filtering --> empty : CLEAR_ALL
    }
  }